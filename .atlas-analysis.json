  "keyFeatures": [
    "Zero dependencies - lightweight and fast",
    "Step-based middleware system for event handling",
    "SpeedyCard builder for Adaptive Cards",
    "Multi-platform support (serverless, workers, standard servers)",
    "Built-in TypeScript support with full type hints",
    "CLI tools for scaffolding and webhook management",
    "File upload and form submission handling",
    "LLM token streaming support"
  ],
  "publicApiSurface": [
    "SpeedyBot - Main bot orchestration class",
    "SpeedyCard - Adaptive card builder",
    "addStep() - Add middleware step",
    "addStepSequence() - Add multiple steps",
    "$.send() - Send messages",
    "$.reply() - Reply to messages",
    "$.card() - Create cards",
    "setToken() - Configure bot token",
    "addSecret() - Store secrets",
    "CLI: speedybot setup - Scaffold projects",
    "CLI: speedybot token - Inspect tokens",
    "CLI: speedybot webhook - Manage webhooks"
